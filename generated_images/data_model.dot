digraph data_model {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Courier", fontsize=10, shape=record, style="filled"];
    edge [fontname="Helvetica", fontsize=9];
    bgcolor="white";
    ranksep=0.8;
    nodesep=0.6;

    /* ══════════════════════════════════════════════
       Cluster ordering (top → bottom):
         1. Core Event Model   (foundation types)
         2. Block Model        (composed from events)
         3. Scene Graph Model  (composed from blocks)
         4. Animation Model  ┐
         5. DOT Layout Model ┘ (parallel consumers)
       ══════════════════════════════════════════════ */

    /* ── Core Event Model ────────────────────── */
    subgraph cluster_events {
        label="Core Event Model  (transform.models)";
        style="filled,rounded"; fillcolor="#e8f5e9"; color="#43a047";
        fontname="Helvetica"; fontsize=12; fontcolor="#1b5e20";
        margin=16;

        ProgramEventStream [label="{ProgramEventStream|source_path : str\l| events : list[IREvent]\l| cfg_edges : list[CFGEdge]\l| display_lines : dict[str, list[str]]\l}",
                            fillcolor="#a5d6a7", color="#2e7d32"];

        IREvent [label="{IREvent|function_name : str\l| block_name : str\l| opcode : str\l| text : str\l| kind : EventKind\l| index_in_function : int\l| debug_line : int | None\l| operands : list[str]\l}",
                 fillcolor="#c8e6c9", color="#2e7d32"];

        EventKind [label="{EventKind\n(Literal type)|alloca | load | store\l| binop | compare | call\l| ret | br | other\l}",
                   fillcolor="#c8e6c9", color="#2e7d32"];

        CFGEdge [label="{CFGEdge|source : str\l| target : str\l| kind : str\l| label : str\l}",
                 fillcolor="#c8e6c9", color="#2e7d32"];
    }

    /* ── Block Model ─────────────────────────── */
    subgraph cluster_blocks {
        label="Block Model  (transform.models)";
        style="filled,rounded"; fillcolor="#fff3e0"; color="#fb8c00";
        fontname="Helvetica"; fontsize=12; fontcolor="#e65100";
        margin=16;

        CFGBlock [label="{CFGBlock|id : str\l| name : str\l| function_name : str\l| events : list[IREvent]\l| terminator_opcode : str | None\l| role : BlockRole\l| indegree / outdegree : int\l| memory_ops : list[IREvent]\l|idom : str | None\l| dom_depth : int\l| is_loop_header : bool\l| loop_depth / loop_id\l| is_backedge_target : bool\l}",
                  fillcolor="#ffe0b2", color="#ef6c00"];

        BlockRole [label="{BlockRole\n(Literal type)|entry | linear | branch\l| merge | exit\l}",
                   fillcolor="#ffe0b2", color="#ef6c00"];

        BlockMetadata [label="{BlockMetadata|idom : str | None\l| dom_depth : int\l| is_loop_header : bool\l| loop_depth : int\l| loop_id : str | None\l| is_backedge_target : bool\l}",
                       fillcolor="#ffe0b2", color="#ef6c00"];
    }

    /* ── Scene Graph Model ───────────────────── */
    subgraph cluster_scene {
        label="Scene Graph Model  (transform.models)";
        style="filled,rounded"; fillcolor="#e3f2fd"; color="#1e88e5";
        fontname="Helvetica"; fontsize=12; fontcolor="#0d47a1";
        margin=16;

        SceneGraph [label="{SceneGraph|nodes : list[SceneNode]\l| edges : list[CFGEdge]\l| overlay : TraceOverlay | None\l}",
                    fillcolor="#90caf9", color="#1565c0"];

        SceneNode [label="{SceneNode|id : str\l| label : str\l| role : BlockRole\l| block : CFGBlock\l| animation_hint : str\l}",
                   fillcolor="#bbdefb", color="#1565c0"];

        TraceOverlay [label="{TraceOverlay|visited_nodes : list[str]\l| traversed_edges : list[tuple]\l| entry_order : list[str]\l| termination_reason : str\l}",
                      fillcolor="#bbdefb", color="#1565c0"];
    }

    /* ── Animation Model ─────────────────────── */
    subgraph cluster_anim {
        label="Animation Model  (transform.commands / present)";
        style="filled,rounded"; fillcolor="#fce4ec"; color="#e53935";
        fontname="Helvetica"; fontsize=12; fontcolor="#b71c1c";
        margin=16;

        AnimationCommand [label="{AnimationCommand|action : ActionKind\l| event : IREvent\l}",
                          fillcolor="#ffcdd2", color="#c62828"];

        ActionKind [label="{ActionKind\n(Literal type)|create_stack_slot\l| animate_memory_read\l| animate_memory_write\l| animate_binop\l| animate_compare\l| push_stack_frame\l| pop_stack_frame\l| highlight_branch\l| signal_stack_underflow\l}",
                    fillcolor="#ffcdd2", color="#c62828"];

        RenderStep [label="{RenderStep|label : str\l| action : ActionKind\l| slot_name : str | None\l| value : str | None\l| frame_label : str | None\l| text : str\l}",
                    fillcolor="#ffcdd2", color="#c62828"];

        LLVManimScene [label="{LLVManimScene|steps : list[RenderStep]\l}",
                       fillcolor="#ef9a9a", color="#c62828"];
    }

    /* ── Layout Model ────────────────────────── */
    subgraph cluster_layout {
        label="DOT Layout Model  (ingest.dot_layout)";
        style="filled,rounded"; fillcolor="#f3e5f5"; color="#8e24aa";
        fontname="Helvetica"; fontsize=12; fontcolor="#4a148c";
        margin=16;

        DotLayout [label="{DotLayout|bounding_box : tuple\l| nodes : dict[str, DotNodeLayout]\l| edges : list[DotEdgeLayout]\l}",
                   fillcolor="#e1bee7", color="#7b1fa2"];

        DotNodeLayout [label="{DotNodeLayout|name : str\l| x, y : float\l| width, height : float\l}",
                       fillcolor="#e1bee7", color="#7b1fa2"];

        DotEdgeLayout [label="{DotEdgeLayout|source, target : str\l| points : list[tuple]\l| label : str\l}",
                       fillcolor="#e1bee7", color="#7b1fa2"];
    }

    /* ── Invisible edges to force vertical cluster ordering ── */
    ProgramEventStream -> CFGBlock [style=invis, weight=10];
    CFGBlock -> SceneGraph         [style=invis, weight=10];
    SceneGraph -> AnimationCommand [style=invis, weight=5];
    SceneGraph -> DotLayout        [style=invis, weight=5];

    /* ── Relationships within Event cluster ──── */
    ProgramEventStream -> IREvent    [label="  events *", color="#2e7d32"];
    ProgramEventStream -> CFGEdge    [label="  cfg_edges *", color="#2e7d32"];
    IREvent            -> EventKind  [label="  kind", style=dashed, color="#66bb6a"];

    /* ── Relationships within Block cluster ──── */
    CFGBlock -> BlockRole    [label="  role", style=dashed, color="#ffa726"];
    BlockMetadata -> CFGBlock [label="  applied to", style=dashed, arrowhead=open, color="#ffa726"];

    /* ── Cross-cluster: Block → Event ────────── */
    CFGBlock -> IREvent [label="  events *", color="#ef6c00", constraint=false];

    /* ── Relationships within Scene cluster ──── */
    SceneGraph -> SceneNode    [label="  nodes *", color="#1565c0"];
    SceneGraph -> TraceOverlay [label="  overlay 0..1", style=dashed, color="#42a5f5"];

    /* ── Cross-cluster: Scene → Block / Event ── */
    SceneGraph -> CFGEdge   [label="  edges *", color="#1565c0", constraint=false];
    SceneNode  -> CFGBlock  [label="  block", color="#1565c0", constraint=false];

    /* ── Relationships within Animation cluster ── */
    AnimationCommand -> ActionKind  [label="  action", style=dashed, color="#e53935"];
    RenderStep       -> ActionKind  [label="  action", style=dashed, color="#e53935"];
    LLVManimScene    -> RenderStep  [label="  steps *", color="#e53935"];

    /* ── Cross-cluster: Animation → Event ────── */
    AnimationCommand -> IREvent [label="  event", color="#e53935", constraint=false];

    /* ── Relationships within Layout cluster ─── */
    DotLayout -> DotNodeLayout [label="  nodes *", color="#7b1fa2"];
    DotLayout -> DotEdgeLayout [label="  edges *", color="#7b1fa2"];
}
