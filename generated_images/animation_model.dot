digraph animation_model {
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Courier", fontsize=13, shape=record, style="filled"];
    edge [fontname="Helvetica", fontsize=11];
    bgcolor="white";
    ranksep=0.7;
    nodesep=0.5;
    label="Animation Model  (transform.commands / render)";
    labelloc=t; fontsize=16; fontcolor="#37474f"; fontname="Helvetica";

    /* ── External reference (from core model) ── */
    IREvent  [label="{IREvent|(...see core model)}", fillcolor="#f5f5f5", color="#bdbdbd",
              fontcolor="#757575"];

    /* ── Present layer (blue) ── */
    LLVManimScene [label="{LLVManimScene|steps : list[RenderStep]\l}",
                   fillcolor="#90caf9", color="#1565c0"];

    RenderStep [label="{RenderStep|label : str\l| action : ActionKind\l| slot_name : str | None\l| value : str | None\l| frame_label : str | None\l| text : str\l}",
                fillcolor="#bbdefb", color="#1565c0"];

    /* ── Transform layer (orange) ── */
    AnimationCommand [label="{AnimationCommand|action : ActionKind\l| event : IREvent\l}",
                      fillcolor="#ffcc80", color="#ef6c00"];

    ActionKind [label="{ActionKind\n(Literal type)|create_stack_slot\l| animate_memory_read\l| animate_memory_write\l| animate_binop\l| animate_compare\l| push_stack_frame\l| pop_stack_frame\l| highlight_branch\l| signal_stack_underflow\l}",
                fillcolor="#ffe0b2", color="#ef6c00"];

    LLVManimScene    -> RenderStep  [label="  steps *", color="#1565c0"];
    AnimationCommand -> ActionKind  [label="  action", style=dashed, color="#ffa726"];
    AnimationCommand -> IREvent     [label="  event", color="#ef6c00"];
    RenderStep       -> ActionKind  [label="  action", style=dashed, color="#1565c0"];
}
