// Extracted subgraph: --export-* output from 05_cli_dispatch
digraph export_output {
    graph [
        fontname = "Helvetica" fontsize = 13
        label    = "--export-trace / --export-cfg-edges / --export-analysis-metadata"
        labelloc = "t" splines = ortho nodesep = 0.55 ranksep = 0.9
        pad = 0.4 bgcolor = "white"
    ]
    node [fontname="Helvetica" fontsize=11 style="filled,rounded" shape=box]
    edge [fontname="Helvetica" fontsize=10 color="#555555" arrowsize=0.85]

    // ── External stub ──────────────────────────────────────────────
    sg [label="SceneGraph\n← Shared pipeline" fillcolor="#f5cba7" fontcolor="#ca6f1e"]

    // ── Internal ───────────────────────────────────────────────────
    subgraph cluster_export {

        label = "--export-trace / --export-cfg-edges / --export-analysis-metadata"
        style = filled fillcolor = "#fef9e7" color = "#f39c12"
        penwidth = 1.5 fontname = "Helvetica" fontsize = 11

        exports [label="ingest/trace_io.py\ningest/cfg_edge_io.py\ningest/analysis_metadata_io.py"
                 fillcolor="#27ae60" fontcolor="white"]
        exp_out [label="trace.json\n/  cfg_edges.json\n/  metadata.json"
                 fillcolor="#e74c3c" fontcolor="white" shape=note]
        exports -> exp_out
    }

    sg -> exports [xlabel=" --export-*" style=dashed]
}
